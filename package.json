    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,mdx,json,css,scss,html,yml,yaml}": [
      "prettier --write"
