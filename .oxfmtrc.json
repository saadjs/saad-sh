{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "always",
  "sortPackageJson": false,
  "ignorePatterns": [
    ".next",
    "out",
    "build",
    "dist",
    "node_modules",
    "pnpm-lock.yaml",
    "*.min.*",
    "src/routeTree.gen.ts",
    ".tanstack",
    ".wrangler"
  ]
}
