{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "saad-sh",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "saad.sh",
      "custom_domain": true,
    },
  ],
  "main": "@tanstack/react-start/server-entry",
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
  },
}
